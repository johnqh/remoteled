# RemoteLED Backend Environment Configuration
# Copy to .env: cp .env.example .env

# Database (PostgreSQL connection string)
DATABASE_URL=postgresql://remoteled:remoteled_dev_password@localhost:5432/remoteled

# API Server
API_HOST=0.0.0.0
API_PORT=9999
API_DEBUG=true

# CORS (comma-separated origins, or "*" for dev)
CORS_ORIGINS=*

# Stripe (https://dashboard.stripe.com/test/apikeys)
# Leave empty to use mock payment only
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Mock Payment (set false to require real Stripe)
ENABLE_MOCK_PAYMENT=true

# BLE Configuration (must match Pi's code.py)
BLE_SERVICE_UUID=000088F4-0000-1000-8000-00805f9b34fb
BLE_CHAR_UUID=00000E32-0000-1000-8000-00805f9b34fb
BLE_KEY=A920

# Authorization expiry (minutes)
AUTH_EXPIRY_MINUTES=5

# GPIO Pins (BCM numbering)
GPIO_PIN_GREEN=17
GPIO_PIN_YELLOW=19
GPIO_PIN_RED=27
